<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ikhwatul Kiraam"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1a5276"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#1a5276"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Our Vision"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1a5276"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To build a strong, united and faithful community guided by Islamic values and brotherhood."
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingExtra="6dp"
            android:paddingBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Our Mission"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1a5276"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. To strengthen the bond of brotherhood among members.\n\n2. To promote Islamic knowledge and practice.\n\n3. To serve the community through charitable activities.\n\n4. To develop leadership and character among youth."
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingExtra="6dp"
            android:paddingBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Our History"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1a5276"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ikhwatul Kiraam was established with the aim of uniting brothers in faith and community service. Since its founding, the organization has grown to become a pillar of the local Muslim community."
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingExtra="6dp"
            android:paddingBottom="24dp"/>

    </LinearLayout>
</ScrollView>