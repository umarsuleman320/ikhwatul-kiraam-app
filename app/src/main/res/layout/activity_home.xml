<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ikhwatul Kiraam"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1a5276"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome to our community"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:paddingBottom="32dp"/>

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="About Us"
            android:textSize="16sp"
            android:backgroundTint="#1a5276"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnMembers"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Members"
            android:textSize="16sp"
            android:backgroundTint="#1a5276"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnEvents"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Events &amp; Announcements"
            android:textSize="16sp"
            android:backgroundTint="#1a5276"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Gallery"
            android:textSize="16sp"
            android:backgroundTint="#1a5276"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnDonations"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Donations"
            android:textSize="16sp"
            android:backgroundTint="#1a5276"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>